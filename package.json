{
  "name": "n8n-nodes-lunchmoney",
  "version": "0.1.0-alpha.0",
  "description": "n8n community node for the LunchMoney V2 API.",
  "license": "MIT",
  "homepage": "https://github.com/x97jtq/lunchmoney-n8n-connector#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/x97jtq/lunchmoney-n8n-connector.git"
  },
  "bugs": {
    "url": "https://github.com/x97jtq/lunchmoney-n8n-connector/issues"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "n8n-node",
    "lunchmoney",
    "personal-finance"
  ],
  "author": "",
  "main": "dist/nodes/LunchMoney/LunchMoney.node.js",
  "types": "dist/nodes/LunchMoney/LunchMoney.node.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rimraf dist coverage",
    "build": "tsc -p tsconfig.build.json && node scripts/copy-assets.cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --ext .ts",
    "test": "jest --runInBand",
    "prepack": "npm run clean && npm run lint && npm run typecheck && npm test && npm run build"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/LunchMoneyApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/LunchMoney/LunchMoney.node.js"
    ]
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "n8n-workflow": "^1.82.0",
    "rimraf": "^5.0.10",
    "ts-jest": "^29.4.0",
    "typescript": "5.5.4"
  },
  "engines": {
    "node": ">=18.10"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
