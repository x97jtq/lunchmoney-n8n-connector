{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "rootDir": ".",
    "outDir": "dist",
    "types": [
      "jest",
      "node"
    ]
  },
  "include": [
    "credentials/**/*.ts",
    "nodes/**/*.ts",
    "test/**/*.ts"
  ],
  "exclude": [
    "dist",
    "coverage",
    "node_modules"
  ]
}
